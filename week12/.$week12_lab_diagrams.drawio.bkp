        <mxCell id="db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="🗄️ PostgreSQL 15&#xa;[Database]&#xa;Port: 5432 (internal only)&#xa;• users table&#xa;• tasks table&#xa;• audit_logs table&#xa;Volume: postgres_data" vertex="1">
