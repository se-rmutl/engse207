        <mxCell id="task" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;fontSize=10;" value="📋 Task Service&#xa;[Node.js / Express]&#xa;Port: 3002 (internal)&#xa;• GET/POST/PATCH/DELETE&#xa;  /api/tasks&#xa;• Verifies JWT Token&#xa;• Role-based Access&#xa;  admin/member/viewer" vertex="1">
          <mxGeometry height="160" width="250" x="550" y="460" as="geometry" />
