        <mxCell id="nginx" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=0;fontSize=10;" value="🛡️ Nginx&#xa;[API Gateway / Rate Limiter]&#xa;Port: 8080 (external)&#xa;• Route /api/auth → :3001&#xa;• Route /api/tasks → :3002&#xa;• Route /api/users → :3003&#xa;• Rate Limit: 100r/min&#xa;• Security Headers" vertex="1">
