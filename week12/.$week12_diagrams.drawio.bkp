        </mxCell>
        <mxCell id="i3" parent="z2M5yUR_bTjzo_viK2aS-2" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=12;align=left;spacingLeft=20;" value=".env file (DB password)&lt;br&gt;ถูก commit ลง Git&lt;br&gt;หรือ API ส่งข้อมูล task&lt;br&gt;ของ user อื่นมาด้วย" vertex="1">
          <mxGeometry height="80" width="210" y="280" as="geometry" />
        </mxCell>
        <mxCell id="d3" parent="z2M5yUR_bTjzo_viK2aS-2" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=12;align=left;spacingLeft=20;" value="ส่ง requests จำนวนมาก&lt;br&gt;ท่วม API Server&lt;br&gt;หรือ create tasks ไม่หยุด&lt;br&gt;ทำให้ DB เต็ม" vertex="1">
          <mxGeometry height="80" width="210" y="360" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="z2M5yUR_bTjzo_viK2aS-2" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=12;align=left;spacingLeft=20;" value="แก้ role ใน JWT payload&lt;br&gt;จาก &quot;member&quot; เป็น &quot;admin&quot;&lt;br&gt;หรือเข้าถึง admin-only&lt;br&gt;endpoints โดยตรง" vertex="1">
          <mxGeometry height="80" width="210" y="440" as="geometry" />
        </mxCell>
        <mxCell id="z2M5yUR_bTjzo_viK2aS-3" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="520" width="240" x="610" y="110" as="geometry" />
        </mxCell>
        <mxCell id="h4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#1a237e;fontColor=#FFFFFF;strokeColor=#1a237e;fontSize=13;verticalAlign=middle;" value="&lt;b&gt;Mitigation&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="240" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• JWT with strong signing (HS256/RS256)&lt;br&gt;• Short token expiry (1hr)&lt;br&gt;• HttpOnly cookies&lt;br&gt;• Refresh token rotation" vertex="1">
          <mxGeometry height="80" width="240" y="40" as="geometry" />
        </mxCell>
        <mxCell id="t4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• Parameterized queries (ORM)&lt;br&gt;• Input validation &amp;amp; sanitization&lt;br&gt;• WAF rules (OWASP CRS)&lt;br&gt;• Server-side ownership check" vertex="1">
          <mxGeometry height="80" width="240" y="120" as="geometry" />
        </mxCell>
        <mxCell id="r4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• Centralized audit logging&lt;br&gt;• Log: who, what, when, from where&lt;br&gt;• Immutable log storage&lt;br&gt;• Tamper-proof timestamps" vertex="1">
          <mxGeometry height="80" width="240" y="200" as="geometry" />
        </mxCell>
        <mxCell id="i4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• .gitignore for .env files&lt;br&gt;• Secret management (Vault)&lt;br&gt;• Data-level access control&lt;br&gt;• HTTPS everywhere" vertex="1">
          <mxGeometry height="80" width="240" y="280" as="geometry" />
        </mxCell>
        <mxCell id="d4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• Rate limiting (100 req/min/IP)&lt;br&gt;• WAF DDoS protection&lt;br&gt;• Resource quotas per user&lt;br&gt;• Auto-scaling (if cloud)" vertex="1">
          <mxGeometry height="80" width="240" y="360" as="geometry" />
        </mxCell>
        <mxCell id="e4" parent="z2M5yUR_bTjzo_viK2aS-3" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=12;align=left;spacingLeft=5;" value="• Server-side role validation&lt;br&gt;• JWT signature verification&lt;br&gt;• RBAC middleware per endpoint&lt;br&gt;• Principle of least privilege" vertex="1">
          <mxGeometry height="80" width="240" y="440" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
