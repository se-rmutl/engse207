        <mxCell id="r3" parent="z2M5yUR_bTjzo_viK2aS-2" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=12;align=left;spacingLeft=20;" value="ผู้ใช้ลบ Task สำคัญ&lt;br&gt;แล้วอ้างว่า &quot;ไม่ได้ทำ&quot;&lt;br&gt;ไม่มีหลักฐานว่าใครลบ" vertex="1">
