          </mxGeometry>
        </mxCell>
        <mxCell id="msg1-l" value="1. POST /auth/login {email, password}" style="edgeLabel;html=1;fontSize=10;fontColor=#1976D2;" vertex="1" connectable="0" parent="msg1">
