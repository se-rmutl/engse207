        <mxCell id="perim-fw" value="&lt;b&gt;Firewall (คูเมือง)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];fontSize=11;fontColor=#D32F2F;" vertex="1" parent="1">
