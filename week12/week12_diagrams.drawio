            <mxPoint x="620" y="120" as="sourcePoint"/>
            <mxPoint x="620" y="750" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="line4" style="dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="870" y="120" as="sourcePoint"/>
            <mxPoint x="870" y="750" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Phase 1: Login -->
        <mxCell id="phase1" value="Phase 1: Login (ขอ Token)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#C5CAE9;fontSize=11;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="140" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="msg1" style="strokeColor=#1976D2;strokeWidth=2;" edge="1" parent="1">
