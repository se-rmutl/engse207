  <diagram id="zero-trust" name="5. Zero-Trust vs Perimeter Security">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title5" value="&lt;b&gt;Perimeter Security (Castle-and-Moat) vs Zero-Trust Architecture&lt;/b&gt;&lt;br&gt;ENGSE207 Week 12" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
