        <mxCell id="i2" value="ข้อมูลรั่วไหลสู่&lt;br&gt;ผู้ไม่มีสิทธิ์" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="370" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="i3" value=".env file (DB password)&lt;br&gt;ถูก commit ลง Git&lt;br&gt;หรือ API ส่งข้อมูล task&lt;br&gt;ของ user อื่นมาด้วย" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="370" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="i4" value="• .gitignore for .env files&lt;br&gt;• Secret management (Vault)&lt;br&gt;• Data-level access control&lt;br&gt;• HTTPS everywhere" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="370" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="i5" value="🔐 Secret Mgmt&lt;br&gt;📋 Service-level&lt;br&gt;access control" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="370" width="150" height="80" as="geometry"/>
        </mxCell>
        <!-- Row D -->
        <mxCell id="d1" value="&lt;b&gt;D&lt;/b&gt;&lt;br&gt;Denial of&lt;br&gt;Service" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e57373;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="450" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="d2" value="ทำให้ระบบ&lt;br&gt;ใช้งานไม่ได้" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="450" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="ส่ง requests จำนวนมาก&lt;br&gt;ท่วม API Server&lt;br&gt;หรือ create tasks ไม่หยุด&lt;br&gt;ทำให้ DB เต็ม" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="450" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="d4" value="• Rate limiting (100 req/min/IP)&lt;br&gt;• WAF DDoS protection&lt;br&gt;• Resource quotas per user&lt;br&gt;• Auto-scaling (if cloud)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="450" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="d5" value="🛡️ WAF&lt;br&gt;🚪 API Gateway&lt;br&gt;(Rate Limiting)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="450" width="150" height="80" as="geometry"/>
        </mxCell>
        <!-- Row E -->
        <mxCell id="e1" value="&lt;b&gt;E&lt;/b&gt;&lt;br&gt;Elevation of&lt;br&gt;Privilege" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#e57373;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="530" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="ยกระดับสิทธิ์&lt;br&gt;เกินที่ได้รับ" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="530" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="แก้ role ใน JWT payload&lt;br&gt;จาก &amp;quot;member&amp;quot; เป็น &amp;quot;admin&amp;quot;&lt;br&gt;หรือเข้าถึง admin-only&lt;br&gt;endpoints โดยตรง" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="530" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="• Server-side role validation&lt;br&gt;• JWT signature verification&lt;br&gt;• RBAC middleware per endpoint&lt;br&gt;• Principle of least privilege" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="530" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="🔑 Auth Service&lt;br&gt;📋 RBAC&lt;br&gt;Middleware" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#90caf9;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="530" width="150" height="80" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="c2-security" name="3. C2 Container Diagram (Security Enhanced)">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
