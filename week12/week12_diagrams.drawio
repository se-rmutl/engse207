          <mxGeometry x="640" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="z-svc2" value="Service B&lt;br&gt;🔒" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#66BB6A;strokeWidth=2;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="z-svc3" value="Service C&lt;br&gt;🔒" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#66BB6A;strokeWidth=2;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="z-db" value="Database&lt;br&gt;🔐" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#66BB6A;strokeWidth=2;fontSize=11;size=10;" vertex="1" parent="1">
