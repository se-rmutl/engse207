  <diagram id="jwt-flow" name="4. JWT Authentication Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title4" value="&lt;b&gt;JWT Authentication Flow: Task Board System&lt;/b&gt;&lt;br&gt;ENGSE207 Week 12" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="10" width="500" height="50" as="geometry"/>
        </mxCell>
        <!-- Lifeline labels -->
        <mxCell id="ll-browser" value="&lt;b&gt;Browser&lt;/b&gt;&lt;br&gt;(User)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="120" height="50" as="geometry"/>
