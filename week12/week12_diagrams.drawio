        </mxCell>
        <mxCell id="t4" value="• Parameterized queries (ORM)&lt;br&gt;• Input validation &amp; sanitization&lt;br&gt;• WAF rules (OWASP CRS)&lt;br&gt;• Server-side ownership check" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
