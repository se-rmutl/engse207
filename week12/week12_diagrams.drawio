        </mxCell>
        <mxCell id="s2" value="ปลอมตัวเป็นผู้ใช้คนอื่น&lt;br&gt;เพื่อเข้าถึงระบบ" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="130" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="ผู้โจมตีปลอม JWT Token&lt;br&gt;หรือขโมย Token จาก&lt;br&gt;localStorage เพื่อเข้าถึง&lt;br&gt;Task ของคนอื่น" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="130" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="• JWT with strong signing (HS256/RS256)&lt;br&gt;• Short token expiry (1hr)&lt;br&gt;• HttpOnly cookies&lt;br&gt;• Refresh token rotation" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="630" y="130" width="280" height="80" as="geometry"/>
