        <mxCell id="msg4" style="strokeColor=#388E3C;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="620" y="310" as="sourcePoint"/>
            <mxPoint x="370" y="310" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg4-l" value="4. JWT Token (access + refresh)" style="edgeLabel;html=1;fontSize=10;fontColor=#388E3C;" vertex="1" connectable="0" parent="msg4">
