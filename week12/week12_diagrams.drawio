          <mxGeometry x="150" y="210" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="SQL Injection ผ่าน&lt;br&gt;task title/description&lt;br&gt;หรือแก้ไข request body&lt;br&gt;เพื่อเปลี่ยน task owner" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e0e0e0;fontSize=11;" vertex="1" parent="1">
