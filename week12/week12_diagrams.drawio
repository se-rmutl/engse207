        </mxCell>
        <mxCell id="z-conn1" value="🔑" style="strokeColor=#66BB6A;strokeWidth=2;" edge="1" source="z-svc1" target="z-svc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="z-conn2" value="🔑" style="strokeColor=#66BB6A;strokeWidth=2;" edge="1" source="z-svc2" target="z-svc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="z-conn3" value="🔑" style="strokeColor=#66BB6A;strokeWidth=2;" edge="1" source="z-svc1" target="z-db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="z-conn4" value="🔑" style="strokeColor=#66BB6A;strokeWidth=2;" edge="1" source="z-svc3" target="z-db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="z-benefit" value="🛡️ ถ้า Attacker เจาะ Service A ได้&lt;br&gt;→ ❌ เข้า B, C, DB ไม่ได้!&lt;br&gt;(ทุก connection ต้อง verify)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#66BB6A;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="340" width="350" height="60" as="geometry"/>
        </mxCell>
        <!-- Bottom: 5 Principles -->
        <mxCell id="principles-title" value="&lt;b&gt;Zero-Trust 5 Principles&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=13;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="410" y="470" width="340" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="pr1" value="1. Verify Explicitly&lt;br&gt;ตรวจสอบทุกครั้ง" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="520" width="190" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pr2" value="2. Least Privilege&lt;br&gt;ให้สิทธิ์น้อยที่สุด" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="520" width="190" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pr3" value="3. Assume Breach&lt;br&gt;สมมติว่าถูกเจาะแล้ว" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="520" width="190" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pr4" value="4. Monitor Everything&lt;br&gt;บันทึกทุกอย่าง" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="710" y="520" width="190" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pr5" value="5. Encrypt Everything&lt;br&gt;เข้ารหัสทุกอย่าง" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#90CAF9;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="520" width="190" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
