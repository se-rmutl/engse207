        </mxCell>
        <mxCell id="p-svc1" value="Service A" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p-svc2" value="Service B" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p-svc3" value="Service C" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="170" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p-db" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;size=10;" vertex="1" parent="1">
          <mxGeometry x="230" y="250" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p-conn1" style="strokeColor=#999;strokeWidth=1;" edge="1" source="p-svc1" target="p-svc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p-conn2" style="strokeColor=#999;strokeWidth=1;" edge="1" source="p-svc2" target="p-svc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p-conn3" style="strokeColor=#999;strokeWidth=1;" edge="1" source="p-svc1" target="p-db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p-conn4" style="strokeColor=#999;strokeWidth=1;" edge="1" source="p-svc3" target="p-db" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p-problem" value="🦠 ถ้า Attacker เจาะ Service A ได้&lt;br&gt;→ เข้าถึง B, C, DB ได้หมด!&lt;br&gt;(เพราะไม่มีการตรวจสอบภายใน)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#EF5350;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="350" height="60" as="geometry"/>
