          <mxGeometry x="560" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ll-task" value="&lt;b&gt;Task Service&lt;/b&gt;&lt;br&gt;(Node.js)" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="70" width="120" height="50" as="geometry"/>
        </mxCell>
        <!-- Lifelines -->
