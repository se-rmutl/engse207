          <mxGeometry relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="msg3" value="3. Verify credentials&lt;br&gt;Generate JWT" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="250" width="130" height="40" as="geometry"/>
