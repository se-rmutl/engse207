        <mxCell id="yml-title" value="📄 docker-compose.yml" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#37474f;" vertex="1" parent="1">
