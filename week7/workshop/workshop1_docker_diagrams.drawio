        <mxCell id="api-content" value="build: .&#xa;ports: 3000:3000&#xa;environment:&#xa;  - DB_HOST=db&#xa;depends_on:&#xa;  db: service_healthy" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;spacingLeft=10;" vertex="1" parent="1">
