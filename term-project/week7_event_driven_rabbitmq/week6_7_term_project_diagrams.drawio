                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cwrite" value="❌ POST/PUT/DELETE&#xa;→ Invalidate Cache" style="rounded=1;fillColor=#FFCDD2;strokeColor=#F44336;fontStyle=1;fontSize=11;" parent="1" vertex="1">
