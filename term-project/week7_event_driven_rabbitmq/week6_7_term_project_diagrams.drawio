                            <mxPoint x="655" y="340"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="csummary" value="Summary:&#xa;🟢 HIT  = Redis → App → Client (~2ms)&#xa;🔴 MISS = Redis → DB → Redis → App → Client (~50ms)&#xa;❌ Write = DB → Delete Redis Keys → Next read = MISS" style="text;html=1;fontSize=10;align=left;fillColor=#F5F5F5;strokeColor=#DDD;rounded=1;" parent="1" vertex="1">
