                    </mxGeometry>
                </mxCell>
                <mxCell id="ce3hit" value="③a HIT → return" style="strokeWidth=2;strokeColor=#4CAF50;dashed=1;fontColor=#2E7D32;fontSize=10;" parent="1" source="credis" target="capp" edge="1">
